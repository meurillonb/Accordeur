{
  "name": "guitartune",
  "version": "2.1.0",
  "description": "Accordeur guitare professionnel PWA avec détection d'accord IA et Tailwind CSS",
  "main": "index.html",
  "scripts": {
    "start": "http-server -p 8000 -c-1 --cors",
    "dev": "http-server -p 8000 -o",
    "build:css": "tailwindcss -i ./style.css -o ./dist/style.min.css --minify",
    "build": "npm run build:css && mkdir -p dist && cp index.html app.js manifest.json sw.js dist/",
    "deploy": "npm run build && npm start"
  },
  "keywords": [
    "guitare",
    "accordeur",
    "tuner",
    "musique",
    "pwa",
    "offline",
    "web-app",
    "tailwindcss",
    "essentia.js",
    "audio",
    "pitch-detection"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "http-server": "^14.1.1",
    "tailwindcss": "^3.4.0"
  },
  "dependencies": {
    "essentia.js": "^0.1.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/meurillonb/Accordeur"
  },
  "pwa": {
    "name": "GuitarTune",
    "short_name": "GuitarTune",
    "theme_color": "#f5a623",
    "background_color": "#060609",
    "display": "standalone"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
